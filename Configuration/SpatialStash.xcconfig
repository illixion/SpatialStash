// Signing configuration.
// LocalSigning.xcconfig (gitignored) overrides DefaultSigning.xcconfig when present.
// Copy LocalSigning.xcconfig.example to LocalSigning.xcconfig to customize.
#include "DefaultSigning.xcconfig"
#include? "LocalSigning.xcconfig"

// Git commit hash, generated by scripts/set-build-info.sh at build time.
// BuildInfo.xcconfig is gitignored and created automatically by the scheme pre-action.
#include "../SpatialStash/BuildInfo.xcconfig"
